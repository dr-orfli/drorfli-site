-next-service-teaser .dr-next-service-arrow:nth-child(2) {\n  animation-delay: .18s;\n}\n\n#dr-next-service-teaser .dr-next-service-arrow:nth-child(3) {\n  animation-delay: .36s;\n}\n\n#dr-next-service-teaser .dr-next-service-core:hover {\n  transform: translateY(-4px) scale(1.015);\n  box-shadow:\n    0 0 0 1px rgba(255,255,255,0.05) inset,\n    0 34px 64px rgba(0,0,0,0.34),\n    -10px 0 38px rgba(37,244,238,0.22),\n    10px 0 38px rgba(254,44,85,0.22);\n}\n\n@keyframes drCardFloat {\n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-7px); }\n}\n\n@keyframes drRotateGlow {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n@keyframes drShadowPulse {\n  0%, 100% { transform: scaleX(0.92); opacity: .55; }\n  50% { transform: scaleX(1); opacity: .75; }\n}\n\n@keyframes drPulseRing {\n  0% { transform: scale(.55); opacity: 0; }\n  20% { opacity: .9; }\n  100% { transform: scale(2.1); opacity: 0; }\n}\n\n@keyframes drLiveDot {\n  0% { box-shadow: 0 0 0 0 rgba(254,44,85,0.55); }\n  70% { box-shadow: 0 0 0 14px rgba(254,44,85,0); }\n  100% { box-shadow: 0 0 0 0 rgba(254,44,85,0); }\n}\n\n@keyframes drTitlePop {\n  0% { transform: translateY(0px) scale(1); }\n  100% { transform: translateY(-1px) scale(1.02); }\n}\n\n@keyframes drSubtitleBlink {\n  0%, 100% { opacity: .78; }\n  50% { opacity: 1; }\n}\n\n@keyframes drArrowDrop {\n  0%, 100% { transform: translateY(0); opacity: .25; }\n  50% { transform: translateY(9px); opacity: 1; }\n}\n\n@media (max-width: 768px) {\n  #dr-next-service-teaser.dr-next-service-teaser {\n    padding: 26px 12px 44px;\n  }\n\n  #dr-next-service-teaser .dr-next-service-core {\n    min-height: 150px;\n    padding: 24px 16px 18px;\n    border-radius: 24px;\n  }\n\n  #dr-next-service-teaser .dr-next-service-title {\n    font-size: 28px;\n    line-height: 1.08;\n  }\n\n  #dr-next-service-teaser .dr-next-service-subtitle {\n    font-size: 15px;\n  }\n\n  #dr-next-service-teaser .dr-next-service-badge {\n    font-size: 11px;\n    padding: 9px 14px;\n  }\n\n  #dr-next-service-teaser .dr-next-service-arrow {\n    font-size: 28px;\n  }\n}\n<\/style>\n\n<script>\nfunction drScrollToNextService() {\n  const teaser = document.getElementById('dr-next-service-teaser');\n  if (!teaser) return;\n\n  const allSections = Array.from(document.querySelectorAll('section, .shopify-section, .section'));\n  let target = null;\n\n  for (const el of allSections) {\n    const rect = el.getBoundingClientRect();\n    if (rect.top > teaser.getBoundingClientRect().top + 60) {\n      target = el;\n      break;\n    }\n  }\n\n  if (!target) {\n    const next = teaser.nextElementSibling;\n    if (next) {\n      next.scrollIntoView({ behavior: 'smooth', block: 'start' });\n    }\n    return;\n  }\n\n  target.scrollIntoView({ behavior: 'smooth', block: 'start' });\n}\n<\/script>","color_scheme":"","padding_top":40,"padding_bottom":52}},"custom_liquid_KGHJec":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<style>\n  .dr-tiktok-hero {\n    position: relative;\n    background: url('https:\/\/cdn.shopify.com\/s\/files\/1\/0660\/8771\/4876\/files\/agent.9d031b53.png?v=1775247632') center\/cover no-repeat;\n    border-radius: 28px;\n    overflow: hidden;\n    padding: 90px 24px;\n    text-align: center;\n  }\n\n  .dr-tiktok-hero::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(\n      180deg,\n      rgba(255,255,255,0.55) 0%,\n      rgba(255,255,255,0.35) 100%\n    );\n  }\n\n  .dr-tiktok-wrap {\n    position: relative;\n    z-index: 2;\n    max-width: 980px;\n    margin: 0 auto;\n  }\n\n  .dr-tiktok-card {\n    background: rgba(255,255,255,0.72);\n    backdrop-filter: blur(8px);\n    -webkit-backdrop-filter: blur(8px);\n    border: 2px solid rgba(255,255,255,0.65);\n    border-radius: 30px;\n    padding: 42px 28px;\n    box-shadow: 0 18px 50px rgba(0,0,0,0.12);\n  }\n\n  .dr-tiktok-title {\