{
  "sections": {
    "page-only-hiders": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n/* ===== THIS TEMPLATE ONLY ===== */\nbody.template-page-library-clean main { padding-top: 20px !important; }\n/* Keep content centered */\nbody.template-page-library-clean main .page-width,\nbody.template-page-library-clean main .content-for-layout { max-width: 1200px; margin: 0 auto; }\n/* Remove any top spacer the promo may set */\nbody.template-page-library-clean .content-for-layout { margin-top: 0 !important; }\n/* Footer + payment rows (bottom clean-up) */\nbody.template-page-library-clean #shopify-section-footer,\nbody.template-page-library-clean .shopify-section-footer,\nbody.template-page-library-clean footer { display: none !important; }\nbody.template-page-library-clean .footer__payment,\nbody.template-page-library-clean .list--payment,\nbody.template-page-library-clean .payment-badges,\nbody.template-page-library-clean .payment-icons,\nbody.template-page-library-clean .payment-logos,\nbody.template-page-library-clean .trust-badges { display: none !important; }\n/* Hide custom-liquid badges sections you highlighted */\nbody.template-page-library-clean [id^='shopify-section-sections-'][id*='_custom_liquid_'] { display: none !important; }\n/* Quiet common chat bubbles on this page */\nbody.template-page-library-clean [class*='chat' i][class*='widget' i],\nbody.template-page-library-clean [class*='chat' i][class*='bubble' i],\nbody.template-page-library-clean .tidio-chat,\nbody.template-page-library-clean [data-shopify-chat] { display: none !important; }\n</style>\n<script>(function(){\n  try{ document.documentElement.classList.add('template-page-library-clean'); document.body&&document.body.classList.add('template-page-library-clean'); }catch(e){}\n  function hide(el){ if(!el) return; try{ el.style.setProperty('display','none','important'); }catch(_){} }\n  function killTopBars(root){ var scope=root||document; var known=['.gta-widget_gta-bar','[class^=\\\"gta-widget_gta-bar\\\"]','[class*=\\\"GSC-BAR-\\\" i]','.gta-content__container','.gta-content__bar','.gta-content__overlay','.gta-content__timer','.gta-content__coupon']; known.forEach(function(s){ scope.querySelectorAll(s).forEach(hide); }); scope.querySelectorAll('body *').forEach(function(el){ try{ var cs=getComputedStyle(el); var rect=el.getBoundingClientRect(); var txt=(el.textContent||'').toLowerCase(); var looks=(cs.position==='fixed'||cs.position==='sticky'||parseInt(cs.zIndex||'0',10)>=1000)&&rect.top<160&&rect.height>=40&&rect.height<=360; var match=/instareach|bulk\\s*buy\\s*coupons|maximizer|save\\s?\\d+%/.test(txt); if(looks&&match) hide(el); }catch(_){} }); scope.querySelectorAll('iframe').forEach(function(f){ try{ var cs=getComputedStyle(f),r=f.getBoundingClientRect(); if((cs.position==='fixed'||cs.position==='sticky')&&r.top<160&&r.height>40) hide(f); }catch(_){} }); try{ document.documentElement.style.setProperty('--header-height','0px'); }catch(_){} }\n  function killBadges(root){ var main=document.querySelector('main'); if(!main) return; var scope=(root&&root.closest&&root.closest('main'))?root:main; var logo=/(visa|mastercard|amex|mada|stc\\s?pay|apple\\s?pay|google\\s?pay|paypal)/i; scope.querySelectorAll('img[alt],svg[aria-label]').forEach(function(n){ var a=(n.getAttribute('alt')||n.getAttribute('aria-label')||''); if(logo.test(a)){ var box=n.closest('section,.section,.page-width,.container,.wrapper,div'); if(box&&!box.closest('footer')&&box.getBoundingClientRect().height<900) hide(box); } }); scope.querySelectorAll('p,div,section').forEach(function(n){ var t=(n.textContent||'').toLowerCase(); if(/only saudi riyal|accepted for payments|usd available during payment/.test(t)){ var box=n.closest('section,.section,.page-width,.container,.wrapper,div'); if(box&&!box.closest('footer')) hide(box); } }); }\n  function run(root){ killTopBars(root); killBadges(root); }\n  run(); new MutationObserver(function(m){ m.forEach(function(rec){ rec.addedNodes&&rec.addedNodes.forEach(function(n){ if(n&&n.nodeType===1) run(n); }); }); }).observe(document.documentElement,{childList:true,subtree:true}); setTimeout(run,1200);\n})();</script>"
