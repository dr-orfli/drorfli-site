    "dlb-counter-js": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<script>(function(){function fmt(n){try{return new Intl.NumberFormat(document.documentElement.lang||navigator.language||'en').format(n)}catch(_){return String(n)}}function set(id,v){var el=document.getElementById(id);if(el)el.textContent=fmt(v)}function todayKey(){return new Date().toISOString().slice(0,10)}function monthKey(){return new Date().toISOString().slice(0,7)}function ns(){return (location.hostname||'dr-orfli.com').toLowerCase().replace(/[^a-z0-9.\\-]/g,'_')}function pageKey(){return (location.pathname||'/').replace(/[^A-Za-z0-9_\\/-]/g,'_')}function hit(key,cb){var url='https://api.countapi.xyz/hit/'+encodeURIComponent(ns())+'/'+encodeURIComponent(key);fetch(url,{method:'GET',cache:'no-store'}).then(function(r){return r.json()}).then(function(d){if(d&&typeof d.value==='number'){cb(d.value)}else{throw 0}}).catch(function(){var k='dlb_'+key;var v=parseInt(localStorage.getItem(k)||'0',10);v=isNaN(v)?1:v+1;localStorage.setItem(k,String(v));cb(v)})}function fillFiles(){document.querySelectorAll('#dlb .dlb-item').forEach(function(item){var a=item.querySelector('a[data-dlb=\\\"download\\\"]');var span=item.querySelector('.dlb-filename');if(!a||!span)return;try{var u=new URL(a.href);span.textContent=decodeURIComponent((u.pathname.split('/').pop()||'').replace(/\\?.*$/,''))||'file'}catch(_){span.textContent=(a.href.split('/').pop()||'file').replace(/\\?.*$/,'')}})}function run(){var base='visits::'+pageKey();hit(base+'::'+todayKey(),function(v){set('dlb-visits-today',v)});hit(base+'::'+monthKey(),function(v){set('dlb-visits-month',v)});hit(base+'::total',function(v){set('dlb-visits-total',v)});fillFiles()}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',run)}else{run()}})();</script>"
      }
    }
